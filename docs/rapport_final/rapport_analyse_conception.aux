\@writefile{lof}{\setforeignlanguage {french}}
\@writefile{lot}{\setforeignlanguage {french}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Diagramme de sequence~: Authentification d'un utilisateur. La fleche (1) initie l'appel HTTP POST \texttt  {/api/v1/auth/login} avec email et password~; les fleches (2)--(3) illustrent la delegation au service Auth externe via WebClient reactif~; la fleche (4) montre le rapatriement du token JWT RS256~; les fleches (5)--(6) representent la creation/mise a jour de l'utilisateur local et le cache des permissions dans Redis~; la fleche (7) retourne le token au client. Le diagramme inclut egalement le flux de validation de token pour les requetes subsequentes (partie droite)~: extraction du token depuis l'en-tete Authorization, validation de la signature RS256, verification de l'expiration, consultation de la blacklist Redis, et injection du contexte de securite.}}{35}{figure.caption.19}\protected@file@percent }
\newlabel{fig:seq_auth}{{5.1}{35}{Diagramme de sequence~: Authentification d'un utilisateur. La fleche (1) initie l'appel HTTP POST \texttt {/api/v1/auth/login} avec email et password~; les fleches (2)--(3) illustrent la delegation au service Auth externe via WebClient reactif~; la fleche (4) montre le rapatriement du token JWT RS256~; les fleches (5)--(6) representent la creation/mise a jour de l'utilisateur local et le cache des permissions dans Redis~; la fleche (7) retourne le token au client. Le diagramme inclut egalement le flux de validation de token pour les requetes subsequentes (partie droite)~: extraction du token depuis l'en-tete Authorization, validation de la signature RS256, verification de l'expiration, consultation de la blacklist Redis, et injection du contexte de securite}{figure.caption.19}{}}
