<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <logger name="com.yowyob.fleet.infrastructure.adapters.outbound.external.KernelAuthAdapter" level="DEBUG"/>
    <logger name="com.yowyob.fleet.infrastructure.config.security.JwtAuthenticationManager" level="DEBUG"/>
    <logger name="com.yowyob.fleet" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="DEBUG"/>
    <logger name="reactor.netty" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
